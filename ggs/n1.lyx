\begin_layout Standard
\begin_inset Formula 
\[
\begin{pmatrix}\mathbf{t}\\
\mathbf{n}\\
\mathbf{b}
\end{pmatrix}^{\prime}=\begin{pmatrix}\kappa\mathbf{n}\\
-\kappa\mathbf{t}-\tau\mathbf{b}\\
\tau\mathbf{n}
\end{pmatrix}=\begin{pmatrix} & \kappa\\
-\kappa &  & -\tau\\
 & \tau
\end{pmatrix}\begin{pmatrix}\mathbf{t}\\
\mathbf{n}\\
\mathbf{b}
