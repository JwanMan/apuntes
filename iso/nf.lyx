\family typewriter
F10
\family default
 para arrancar con los cambios o 
\family typewriter
Esc
\family default
 para descartarlos y volver al menú.
\end_layout

\begin_layout Itemize
Línea de órdenes: Permite ejecutar órdenes de GRUB 2, y se accede pulsando
 
\family typewriter
c
\family default
 desde el menú o 
\family typewriter
F2
\family default
 desde el editor.
\end_layout

