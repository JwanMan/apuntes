\end_layout

\begin_layout Labeling
\labelwidthstring 00.00.0000

\family typewriter
\series bold
core.img
\family default
\series default
 Imagen principal, construida dinámicamente a partir de 
\family typewriter
diskboot.img
\family default
/
\family typewriter
cdboot.img
\family default
, 
\family typewriter
kernel.img
\family default
