;
\end_layout

\end_inset

 
\begin_inset Formula $(a-b)c=ac-bc$
\end_inset


\begin_inset Note Comment
status open

\begin_layout Plain Layout
, pues 
\begin_inset Formula $(a-b)c+bc=ac-bc+bc=ac\implies ac-bc=(a-b)c$
