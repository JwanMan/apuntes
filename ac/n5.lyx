\begin_inset Formula 
\[
v=p(f)^{m}(R(f)(v))+G(f)(S(f)(v))=R(f)(p(f)^{m}(v))+S(f)(G(f)(v)),
\]

\end_inset

y por el teorema de Cayley-Hamilton, 
\begin_inset Formula $(p^{m}G)(f)=p^{m}(f)\circ G(f)=G(f)\circ p^{m}(f)=0$
\end_inset

