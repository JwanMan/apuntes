 &  &  & \boxed{C(F)}
\end{pmatrix}\in{\cal M}_{rn}(K),
\]

\end_inset

donde
\begin_inset Formula 
\[
U\coloneqq\begin{pmatrix} &  & 1\\
\\
\\
\end{pmatrix}\in{\cal M}_{n}(K).
\]

