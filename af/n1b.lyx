\begin_layout Enumerate
Para 
\begin_inset Formula $x,y\in H$
\end_inset

, 
\begin_inset Formula $\Vert x+y\Vert^{2}=\Vert x\Vert^{2}+\Vert y\Vert^{2}+2\text{Re}\langle x,y\rangle$
\end_inset

.
