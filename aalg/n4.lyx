\begin_layout Standard
\begin_inset Formula $A,B\in M_{n}(K)$
\end_inset

 son 
\series bold
semejantes
\series default
 si 
\begin_inset Formula $\exists P\in M_{n}(K):B=P^{-1}AP$
\end_inset

.
\end_layout

