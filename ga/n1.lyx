\begin_inset Formula $[1][b]=[1b]=[b]$
\end_inset

, luego 
\begin_inset Formula $[0]$
\end_inset

 y 
\begin_inset Formula $[1]$
\end_inset

 son respectivamente el 0 y el 1.
 Finalmente, para 
\begin_inset Formula $a\in A$
\end_inset

, 
\begin_inset Formula $[-a]+[a]=[-a+a]=[0]$
\end_inset

, luego todo elemento 
\begin_inset Formula $[a]$
\end_inset

 tiene opuesto 
\begin_inset Formula $[-a]$
\end_inset

.
\end_layout

