\begin_inset Formula $A$
\end_inset

, 
\begin_inset Formula $I_{1}\cdots I_{n}=\left(\left\{ x_{1}\cdots x_{n}\right\} _{x_{k}\in I_{k}}\right)$
\end_inset

.
\end_layout

